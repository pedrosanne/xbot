datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Setting {
  id                  String   @id @default("system")
  whatsappToken       String   @default("")
  whatsappPhoneId     String   @default("")
  whatsappVerifyToken String   @default("antigravity_token_123")
  geminiApiKey        String   @default("")
  elevenLabsApiKey    String   @default("")
  elevenLabsVoiceId   String   @default("21m00Tcm4TlvDq8ikWAM") // Rachel
  vapidPublicKey      String   @default("")
  vapidPrivateKey     String   @default("")
  vapiApiKey          String   @default("")
  vapiPhoneNumberId   String   @default("")
  vapiAssistantId     String   @default("")
  updatedAt           DateTime @updatedAt
}

model Agent {
  id           String   @id @default(uuid())
  name         String
  description  String   @default("")
  systemPrompt String   @default("Você é um atendente virtual simpático da nossa empresa. Responda de maneira clara, prestativa e natural, simulando um contato humano.")
  model        String   @default("gemini-1.5-flash")
  temperature  Float    @default(0.7)
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Contact {
  id              String    @id
  name            String    @default("Cliente WhatsApp")
  profileName     String    @default("")
  email           String    @default("")
  notes           String    @default("")
  tags            String    @default("")
  avatarUrl       String    @default("")
  status          String    @default("AUTO") // "AUTO" ou "MANUAL" (transbordo humano)
  botMode         String    @default("FLOW") // "FLOW" ou "IA"
  currentStepId   String    @default("")
  activeFlowId    String    @default("")
  lastInteraction DateTime  @default(now())
  messages        Message[]
  calls           Call[]
  createdAt       DateTime  @default(now())
  
  // Scoping fields for multi-number support
  phoneNumberId   String    @default("")
  clientPhone     String    @default("")
  connectionId    String?
  connection      WhatsAppConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model WhatsAppConnection {
  id                  String    @id @default(uuid())
  name                String    // Ex: "Vendas", "Suporte"
  phoneNumber         String    @default("") // Ex: +5511999999999
  whatsappToken       String    @default("")
  whatsappPhoneId     String    @unique
  whatsappVerifyToken String    @default("antigravity_token_123")
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  contacts            Contact[]
}

model Message {
  id          String   @id // Message ID retornado pelo WhatsApp
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  direction   String   // "INCOMING" (cliente para bot) ou "OUTGOING" (bot/humano para cliente)
  senderType  String   // "BOT", "HUMAN", "CLIENT"
  type        String   // "text", "image", "audio", "video", "document"
  content     String   // Texto ou legenda da mídia
  mediaUrl    String   @default("") // Caminho local do arquivo salvo no Next.js public
  sendError   String   @default("") // Erro de entrega se falhar
  timestamp   DateTime @default(now())
}

model ProcessedWebhook {
  id          String   @id // Message ID do WhatsApp para evitar processar duplicados
  processedAt DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Hashed password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Flow {
  id        String   @id @default(uuid())
  name      String
  trigger   String   @default("keyword") // "welcome" or "keyword"
  keywords  String   @default("")        // comma-separated trigger keywords
  isActive  Boolean  @default(true)
  steps     String   @default("[]")      // JSON string of steps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id        String   @id @default(uuid())
  level     String   @default("INFO") // "INFO", "WARN", "ERROR"
  category  String   @default("SYSTEM") // "WEBHOOK", "FLOW", "API", "DATABASE", "AI"
  message   String
  details   String   @default("") // Trace do erro ou dados do payload
  timestamp DateTime @default(now())
}

model PushSubscription {
  id         String   @id @default(uuid())
  endpoint   String   @unique
  keysAuth   String
  keysP256dh String
  createdAt  DateTime @default(now())
}

model Call {
  id            String   @id @default(uuid())
  contactId     String
  contact       Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  vapiCallId    String   @default("")
  type          String   @default("outbound") // "outbound" ou "inbound"
  status        String   @default("queued")   // "queued","ringing","in-progress","completed","failed","no-answer","busy"
  duration      Int      @default(0)
  transcript    String   @default("")
  recordingUrl  String   @default("")
  summary       String   @default("")
  cost          Float    @default(0)
  endedReason   String   @default("")
  createdAt     DateTime @default(now())
}

model Upload {
  id        String   @id @default(uuid())
  filename  String   @unique
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())
}

