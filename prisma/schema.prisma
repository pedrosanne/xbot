generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Setting {
  id                  String   @id @default("system")
  whatsappToken       String   @default("")
  whatsappPhoneId     String   @default("")
  whatsappVerifyToken String   @default("antigravity_token_123")
  geminiApiKey        String   @default("")
  elevenLabsApiKey    String   @default("")
  elevenLabsVoiceId   String   @default("21m00Tcm4TlvDq8ikWAM")
  updatedAt           DateTime @updatedAt
  vapidPrivateKey     String   @default("")
  vapidPublicKey      String   @default("")
  vapiApiKey          String   @default("")
  vapiAssistantId     String   @default("")
  vapiPhoneNumberId   String   @default("")
  publicBaseUrl       String   @default("")
  globalPixelId       String   @default("")
  globalPixelTestCode String   @default("")
  globalPixelToken    String   @default("")
  emailApiKey         String   @default("")
  emailProvider       String   @default("resend")
  emailSender         String   @default("")
  pushBodyAlert       String   @default("{mensagem}")
  pushBodyLead        String   @default("{mensagem}")
  pushBodyManual      String   @default("{mensagem}")
  pushBodySale        String   @default("R$ {valor} - {nome}")
  pushSoundAlert      String   @default("default")
  pushSoundLead       String   @default("message")
  pushSoundManual     String   @default("default")
  pushSoundSale       String   @default("sale")
  pushTitleAlert      String   @default("Alerta do Sistema ⚠️")
  pushTitleLead       String   @default("Ação Necessária: {nome} 👤")
  pushTitleManual     String   @default("Atendimento Manual: {nome} 💬")
  pushTitleSale       String   @default("Venda Aprovada! 🎉")
  geminiPixPrompt     String   @default("Analise o seguinte texto enviado por um cliente que quer fazer um pagamento e extraia o valor numérico em reais (BRL).\nResponda APENAS com o número decimal puro (ex: 150.00 ou 30.50), usando ponto como separador decimal.\nSe o texto não contiver nenhuma menção de valor ou quantidade financeira, responda EXATAMENTE \"null\" (sem aspas).\n\nTexto do cliente: \"{texto}\"")
  geminiPixModel      String   @default("gemini-2.5-flash")
}

model Agent {
  id                String              @id @default(uuid())
  name              String
  description       String              @default("")
  systemPrompt      String              @default("Você é um atendente virtual simpático da nossa empresa. Responda de maneira clara, prestativa e natural, simulando um contato humano.")
  model             String              @default("gemini-1.5-flash")
  temperature       Float               @default(0.7)
  isActive          Boolean             @default(false)
  createdAt         DateTime            @default(now())
  elevenLabsApiKey  String              @default("")
  elevenLabsVoiceId String              @default("")
  geminiApiKey      String              @default("")
  connectionId      String?
  productId         String?
  connection        WhatsAppConnection? @relation(fields: [connectionId], references: [id])
  product           Product?            @relation(fields: [productId], references: [id])
  flows             Flow[]
}

model Contact {
  id                String              @id
  name              String              @default("Cliente WhatsApp")
  profileName       String              @default("")
  status            String              @default("AUTO")
  lastInteraction   DateTime            @default(now())
  createdAt         DateTime            @default(now())
  activeFlowId      String              @default("")
  botMode           String              @default("FLOW")
  currentStepId     String              @default("")
  avatarUrl         String              @default("")
  email             String              @default("")
  notes             String              @default("")
  tags              String              @default("")
  clientPhone       String              @default("")
  connectionId      String?
  phoneNumberId     String              @default("")
  designatedAgentId String?
  typingState       String              @default("IDLE")
  assignedUserId    String?
  passedFlows       String              @default("")
  fbc               String              @default("")
  fbp               String              @default("")
  utmCampaign       String              @default("")
  utmContent        String              @default("")
  utmMedium         String              @default("")
  utmSource         String              @default("")
  utmTerm           String              @default("")
  isBlocked         Boolean             @default(false)
  isPinned          Boolean             @default(false)
  reminderDate      DateTime?
  flowStepEnteredAt DateTime            @default(now())
  calls             Call[]
  assignedUser      User?               @relation(fields: [assignedUserId], references: [id])
  connection        WhatsAppConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages          Message[]
  payments          Payment[]

  @@index([connectionId])
  @@index([assignedUserId])
  @@index([lastInteraction])
  @@index([clientPhone])
  @@index([email])
}

model WhatsAppConnection {
  id                    String    @id @default(uuid())
  name                  String
  phoneNumber           String    @default("")
  whatsappToken         String    @default("")
  whatsappPhoneId       String    @unique
  whatsappVerifyToken   String    @default("antigravity_token_123")
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  currentDayLeads       Int       @default(0)
  dailyLeadLimit        Int       @default(1000)
  distributionWeight    Int       @default(1)
  isDistributionEnabled Boolean   @default(false)
  messagingTier         String    @default("TIER_1K")
  qualityRating         String    @default("GREEN")
  statusMeta            String    @default("CONNECTED")
  agents                Agent[]
  contacts              Contact[]
  flows                 Flow[]
  users                 User[]    @relation("UserToWhatsAppConnection")
}

model Message {
  id             String   @id
  contactId      String
  direction      String
  senderType     String
  type           String
  content        String
  mediaUrl       String   @default("")
  timestamp      DateTime @default(now())
  sendError      String   @default("")
  status         String   @default("sent")
  deletedFor     String   @default("")
  isDeleted      Boolean  @default(false)
  isEdited       Boolean  @default(false)
  reactions      String   @default("[]")
  replyToContent String   @default("")
  replyToId      String   @default("")
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([timestamp])
}

model ProcessedWebhook {
  id          String   @id
  processedAt DateTime @default(now())
}

model User {
  id                String               @id @default(uuid())
  name              String
  email             String               @unique
  password          String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  assignedContacts  Contact[]
  sales             Payment[]            @relation("PaymentSeller")
  pushSubscriptions PushSubscription[]
  connections       WhatsAppConnection[] @relation("UserToWhatsAppConnection")
}

model Flow {
  id           String              @id @default(uuid())
  name         String
  trigger      String              @default("keyword")
  keywords     String              @default("")
  isActive     Boolean             @default(true)
  steps        String              @default("[]")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  agentId      String?
  connectionId String?
  productId    String?
  agent        Agent?              @relation(fields: [agentId], references: [id])
  connection   WhatsAppConnection? @relation(fields: [connectionId], references: [id])
  product      Product?            @relation(fields: [productId], references: [id])
}

model Log {
  id        String   @id @default(uuid())
  level     String   @default("INFO")
  category  String   @default("SYSTEM")
  message   String
  details   String   @default("")
  timestamp DateTime @default(now())

  @@index([timestamp])
}

model PushSubscription {
  id         String   @id @default(uuid())
  endpoint   String   @unique
  keysAuth   String
  keysP256dh String
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Call {
  id           String   @id @default(uuid())
  contactId    String
  vapiCallId   String   @default("")
  type         String   @default("outbound")
  status       String   @default("queued")
  duration     Int      @default(0)
  transcript   String   @default("")
  recordingUrl String   @default("")
  summary      String   @default("")
  cost         Float    @default(0)
  endedReason  String   @default("")
  createdAt    DateTime @default(now())
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model Upload {
  id        String   @id @default(uuid())
  filename  String   @unique
  mimeType  String
  createdAt DateTime @default(now())
}

model PaymentGateway {
  id            String    @id @default(uuid())
  name          String
  type          String
  isActive      Boolean   @default(true)
  apiKey        String    @default("")
  publicKey     String    @default("")
  webhookSecret String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]
}

model Payment {
  id            String         @id @default(uuid())
  gatewayId     String
  contactId     String?
  externalId    String         @default("")
  amount        Float
  status        String         @default("PENDING")
  paymentMethod String         @default("pix")
  description   String         @default("")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  productId     String?
  sellerId      String?
  contact       Contact?       @relation(fields: [contactId], references: [id])
  gateway       PaymentGateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  product       Product?       @relation(fields: [productId], references: [id])
  seller        User?          @relation("PaymentSeller", fields: [sellerId], references: [id])

  @@index([contactId])
  @@index([gatewayId])
  @@index([sellerId])
  @@index([externalId])
}

model Product {
  id             String      @id @default(uuid())
  name           String
  description    String      @default("")
  type           String      @default("DIGITAL")
  price          Float       @default(0.0)
  imageUrl       String      @default("")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  postSaleFlowId String?
  agents         Agent[]
  flows          Flow[]
  offers         Offer[]
  orderBumps     OrderBump[] @relation("BumpMainProduct")
  bumpedIn       OrderBump[] @relation("BumpTargetProduct")
  payments       Payment[]
  pixels         Pixel[]
  upsells        Upsell[]    @relation("UpsellMainProduct")
  upselledIn     Upsell[]    @relation("UpsellTargetProduct")
}

model Offer {
  id          String   @id @default(uuid())
  productId   String
  name        String
  price       Float
  description String   @default("")
  code        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model OrderBump {
  id              String   @id @default(uuid())
  productId       String
  targetProductId String
  title           String
  description     String   @default("")
  price           Float
  createdAt       DateTime @default(now())
  product         Product  @relation("BumpMainProduct", fields: [productId], references: [id], onDelete: Cascade)
  targetProduct   Product  @relation("BumpTargetProduct", fields: [targetProductId], references: [id], onDelete: Cascade)
}

model Upsell {
  id              String   @id @default(uuid())
  productId       String
  targetProductId String
  title           String
  description     String   @default("")
  price           Float
  createdAt       DateTime @default(now())
  product         Product  @relation("UpsellMainProduct", fields: [productId], references: [id], onDelete: Cascade)
  targetProduct   Product  @relation("UpsellTargetProduct", fields: [targetProductId], references: [id], onDelete: Cascade)
}

model Pixel {
  id        String   @id @default(uuid())
  productId String
  platform  String
  pixelId   String
  token     String   @default("")
  createdAt DateTime @default(now())
  testCode  String   @default("")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Broadcast {
  id          String         @id @default(uuid())
  name        String
  status      String         @default("PENDING")
  message     String
  flowId      String?
  senderIds   String
  totalLeads  Int            @default(0)
  sentLeads   Int            @default(0)
  failedLeads Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  logs        BroadcastLog[]
}

model BroadcastLog {
  id          String    @id @default(uuid())
  broadcastId String
  contactId   String
  status      String
  error       String    @default("")
  timestamp   DateTime  @default(now())
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
}

model UtmTracker {
  id          String   @id
  utmSource   String   @default("")
  utmMedium   String   @default("")
  utmCampaign String   @default("")
  utmContent  String   @default("")
  utmTerm     String   @default("")
  fbp         String   @default("")
  fbc         String   @default("")
  createdAt   DateTime @default(now())
  flowId      String   @default("")
}

model Page {
  id                 String   @id @default(uuid())
  title              String
  slug               String   @unique
  description        String   @default("")
  status             String   @default("DRAFT")
  content            Json
  facebookPixelId    String   @default("")
  facebookPixelToken String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model FacebookConfig {
  id          String   @id @default(uuid())
  accessToken String
  adAccountId String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailCampaign {
  id              String     @id @default(uuid())
  name            String
  subject         String
  body            String
  status          String     @default("PENDING")
  totalRecipients Int        @default(0)
  sentCount       Int        @default(0)
  failedCount     Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  logs            EmailLog[]
}

model EmailLog {
  id         String        @id @default(uuid())
  campaignId String
  contactId  String
  status     String
  error      String        @default("")
  timestamp  DateTime      @default(now())
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model GroupAutomation {
  id        String   @id @default(uuid())
  name      String
  type      String
  event     String
  target    String
  message   String   @default("")
  productId String?
  isActive  Boolean  @default(true)
  apiType   String   @default("official")
  apiUrl    String   @default("")
  apiToken  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiUsage {
  id        String   @id @default(uuid())
  provider  String   @default("GEMINI")
  model     String   @default("")
  action    String   @default("")
  tokens    Int      @default(0)
  cost      Float    @default(0)
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([provider])
}
